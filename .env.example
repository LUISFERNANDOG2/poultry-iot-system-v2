# Local Docker configuration
POSTGRES_USER=avicola_local_user
POSTGRES_PASSWORD=change_me_local_postgres_password
POSTGRES_DB=avicola_local_db

# Flask
FLASK_ENV=development
SECRET_KEY=change_me_local_flask_secret

# MQTT local-only defaults
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_TOPIC=sensor/+/data

# Internal service URLs used by Docker Compose
API_BASE_URL=http://api:5000
API_URL=http://api:5000/lecturas
